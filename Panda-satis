<!DOCTYPE html>

<html lang="az">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Panda Satış Sistemi</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #f2f2ee;
  --card: #ffffff;
  --navy: #1a2740;
  --navy2: #243352;
  --gold: #c9963a;
  --border: #e0dfd8;
  --muted: #888880;
  --text: #1a1a1a;
  --blue:    #2E75B6;
  --orange:  #C55A11;
  --green:   #375623;
  --blue-l:  #d0e4f5;
  --orange-l:#fce0cc;
  --green-l: #d4edcc;
  --row-alt: #f8f8f5;
  --total-bg:#e4e4de;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'IBM Plex Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
.screen{display:none;min-height:100vh;flex-direction:column;}
.screen.active{display:flex;}

/* GATE */
#gate{background:var(–navy);align-items:center;justify-content:center;}
.gate-wrap{width:100%;max-width:380px;padding:52px 28px;display:flex;flex-direction:column;gap:20px;align-items:center;}
.gate-logo{font-size:46px;}
.gate-title{font-size:22px;font-weight:700;color:#fff;text-align:center;}
.gate-sub{font-size:13px;color:rgba(255,255,255,.4);text-align:center;margin-top:-12px;}
.gate-label{width:100%;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;color:rgba(255,255,255,.4);margin-bottom:-12px;}
.gate-input{width:100%;background:rgba(255,255,255,.08);border:1.5px solid rgba(255,255,255,.15);border-radius:12px;padding:13px 18px;font-family:inherit;font-size:15px;color:#fff;outline:none;transition:border .15s;}
.gate-input:focus{border-color:var(–gold);}
.gate-input.pw{letter-spacing:5px;font-size:18px;}
.gate-input.pw::placeholder{letter-spacing:1px;font-size:14px;}
select.gate-input{appearance:none;cursor:pointer;}
select.gate-input option{color:#000;background:#fff;}
.gate-btn{width:100%;padding:14px;background:var(–gold);border:none;border-radius:12px;font-family:inherit;font-size:15px;font-weight:700;color:#fff;cursor:pointer;transition:opacity .15s;}
.gate-btn:hover{opacity:.88;}
.gate-err{color:#fca5a5;font-size:13px;display:none;text-align:center;}
.gate-err.show{display:block;}
.gate-divider{width:100%;height:1px;background:rgba(255,255,255,.1);}
.gate-admin-link{color:rgba(255,255,255,.35);font-size:12px;cursor:pointer;background:none;border:none;font-family:inherit;transition:color .15s;}
.gate-admin-link:hover{color:var(–gold);}

/* STORE FORM */
#store-form{background:var(–bg);}
.sf-header{background:var(–navy);padding:20px 24px 26px;}
.sf-header-inner{max-width:620px;margin:0 auto;}
.back-btn{background:none;border:none;color:rgba(255,255,255,.45);font-family:inherit;font-size:13px;cursor:pointer;padding:0;margin-bottom:10px;display:flex;align-items:center;gap:5px;}
.back-btn:hover{color:var(–gold);}
.sf-title{font-size:20px;font-weight:700;color:#fff;}
.sf-date{font-size:12px;color:var(–gold);margin-top:4px;}
.sf-body{max-width:620px;margin:0 auto;padding:24px;flex:1;}

.year-block{background:var(–card);border-radius:14px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.06);margin-bottom:16px;}
.year-header{padding:11px 16px;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:#fff;}
.year-table{width:100%;border-collapse:collapse;}
.year-table thead th{padding:9px 14px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.6px;color:#555;background:#f8f8f5;text-align:right;}
.year-table thead th:first-child{text-align:left;}
.year-table tbody tr{border-top:1px solid var(–border);}
.year-table tbody td{padding:10px 14px;}
.year-table tbody td.pname{font-weight:600;font-size:14px;color:var(–navy);}
.num-inp{width:100%;text-align:right;border:1.5px solid var(–border);border-radius:8px;padding:8px 10px;font-family:‘IBM Plex Mono’,monospace;font-size:14px;font-weight:500;color:var(–text);background:#fff;outline:none;transition:border .15s;}
.num-inp:focus{border-color:var(–gold);}
.num-inp:disabled{background:var(–row-alt);color:var(–muted);cursor:not-allowed;}
.sf-save-btn{width:100%;padding:15px;background:var(–navy);border:none;border-radius:12px;color:#fff;font-family:inherit;font-size:15px;font-weight:700;cursor:pointer;transition:background .15s;margin-top:4px;}
.sf-save-btn:hover{background:var(–navy2);}
.sf-save-btn:disabled{opacity:.5;cursor:not-allowed;}
.success-box{display:none;background:#dcfce7;border:1.5px solid #86efac;border-radius:12px;padding:14px 18px;color:#15803d;font-size:14px;font-weight:500;margin-top:12px;}
.success-box.show{display:block;}
.loading-box{display:none;background:#dbeafe;border:1.5px solid #93c5fd;border-radius:12px;padding:14px 18px;color:#1d4ed8;font-size:14px;margin-top:12px;}
.loading-box.show{display:block;}
.error-box{display:none;background:#fee2e2;border:1.5px solid #fca5a5;border-radius:12px;padding:14px 18px;color:#dc2626;font-size:14px;margin-top:12px;}
.error-box.show{display:block;}

/* ADMIN */
#admin{background:var(–bg);}
.adm-header{background:var(–navy);padding:20px 24px 26px;}
.adm-header-inner{max-width:1150px;margin:0 auto;display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:12px;}
.adm-title h2{font-size:20px;font-weight:700;color:#fff;}
.adm-title p{font-size:12px;color:var(–gold);margin-top:3px;}
.adm-actions{display:flex;gap:10px;align-items:center;}
.refresh-btn{background:rgba(201,150,58,.2);border:1px solid rgba(201,150,58,.4);color:var(–gold);border-radius:9px;padding:8px 14px;font-family:inherit;font-size:13px;cursor:pointer;transition:all .15s;}
.refresh-btn:hover{background:rgba(201,150,58,.3);}
.adm-body{max-width:1150px;margin:0 auto;padding:24px;overflow-x:auto;}

.report-wrap{background:var(–card);border-radius:16px;overflow:hidden;box-shadow:0 1px 6px rgba(0,0,0,.07);min-width:760px;}
.report-table{width:100%;border-collapse:collapse;}
.report-table .rh-group th{padding:10px 12px;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#fff;text-align:center;}
.report-table .rh-group .th-lbl{background:#2d2d2d;color:rgba(255,255,255,.55);font-size:10px;text-align:left;padding:10px 12px;}
.report-table .rh-sub th{padding:8px 12px;font-size:11px;font-weight:600;color:#333;text-align:right;}
.report-table .rh-sub .th-lbl{text-align:left;background:#3a3a3a;color:rgba(255,255,255,.55);font-size:10px;}
.report-table tbody tr{border-bottom:1px solid var(–border);}
.report-table tbody tr:nth-child(even) td{background:var(–row-alt);}
.report-table tbody td{padding:11px 12px;font-size:13px;}
.report-table tbody td.td-name{font-weight:600;color:var(–navy);white-space:nowrap;}
.report-table tbody td.td-num{text-align:right;font-family:‘IBM Plex Mono’,monospace;font-size:13px;font-weight:500;}
.report-table tbody td.td-pct{text-align:right;font-family:‘IBM Plex Mono’,monospace;font-size:12px;color:var(–muted);}
.report-table tbody td.td-dash{text-align:center;color:#ccc;}
.report-table tfoot tr td{padding:12px;font-size:13px;background:var(–total-bg)!important;border-top:2px solid #bbb;}
.report-table tfoot td.td-name{font-weight:700;color:var(–navy);}
.report-table tfoot td.td-num{text-align:right;font-family:‘IBM Plex Mono’,monospace;font-weight:700;}
.report-table tfoot td.td-pct{text-align:right;font-family:‘IBM Plex Mono’,monospace;font-size:12px;font-weight:700;}

.bg-blue{background:var(–blue)!important;}
.bg-orange{background:var(–orange)!important;}
.bg-green{background:var(–green)!important;}
.sub-blue{background:var(–blue-l)!important;}
.sub-orange{background:var(–orange-l)!important;}
.sub-green{background:var(–green-l)!important;}

.adm-loading{text-align:center;padding:40px;color:var(–muted);font-size:14px;}
</style>

</head>
<body>

<!-- LOGIN -->

<div class="screen active" id="gate">
  <div class="gate-wrap">
    <div class="gate-logo">🏪</div>
    <div class="gate-title">Panda Satış Sistemi</div>
    <div class="gate-sub">Daxil olmaq üçün şöbənizi seçin</div>
    <div class="gate-label">Şöbə</div>
    <select class="gate-input" id="gate-store">
      <option value="">— Seçin —</option>
    </select>
    <div class="gate-label">Şifrə</div>
    <input class="gate-input pw" type="password" id="gate-pw" placeholder="••••" onkeydown="if(event.key==='Enter')doLogin()">
    <button class="gate-btn" onclick="doLogin()">Daxil ol →</button>
    <div class="gate-err" id="gate-err">Şifrə yanlışdır</div>
    <div class="gate-divider"></div>
    <button class="gate-admin-link" onclick="showAdminGate()">Admin paneli →</button>
  </div>
</div>

<!-- STORE FORM -->

<div class="screen" id="store-form">
  <div class="sf-header">
    <div class="sf-header-inner">
      <button class="back-btn" onclick="logout()">← Çıxış</button>
      <div class="sf-title" id="sf-title"></div>
      <div class="sf-date" id="sf-date"></div>
    </div>
  </div>
  <div class="sf-body" id="sf-body"></div>
</div>

<!-- ADMIN -->

<div class="screen" id="admin">
  <div class="adm-header">
    <div class="adm-header-inner">
      <div class="adm-title">
        <h2>📊 Yekun Satış Hesabatı</h2>
        <p id="adm-date"></p>
      </div>
      <div class="adm-actions">
        <button class="refresh-btn" onclick="loadAdminData()">↻ Yenilə</button>
        <button class="back-btn" style="color:rgba(255,255,255,.45);margin:0" onclick="logout()">← Çıxış</button>
      </div>
    </div>
  </div>
  <div class="adm-body">
    <div class="report-wrap">
      <div class="adm-loading" id="adm-loading">Məlumatlar yüklənir...</div>
      <table class="report-table" id="report-tbl" style="display:none"></table>
    </div>
  </div>
</div>

<script>
// ══════════════════════════════════════════════
// CONFIG
// ══════════════════════════════════════════════
const API_URL = "https://script.google.com/macros/s/AKfycbwkXaCbgBOdh4L4paDgTJ5jMTDCw8x2j_evMqk15FkHTCTPli9L8hjcq2SfgaZSUVOl/exec";
const ADMIN_PW = "admin2026";

const STORES = [
  { id:"panda2",   name:"Panda 2",            pw:"p2-2026" },
  { id:"panda3",   name:"Panda 3",            pw:"p3-2026" },
  { id:"pandaexp", name:"Panda Express",      pw:"pe-2026" },
  { id:"saxa1",    name:"Saxa 1 (Əcəmi)",    pw:"s1-2026" },
  { id:"saxa2",    name:"Saxa 2 (Xırdalan)", pw:"s2-2026" },
];

const SAXA_IDS = ["saxa1","saxa2"];
const YEARS = [2026, 2025, 2024];
const YEAR_BG  = ["bg-blue",   "bg-orange",  "bg-green"];
const YEAR_SUB = ["sub-blue",  "sub-orange", "sub-green"];
const YEAR_HDR = ["var(--blue)","var(--orange)","var(--green)"];

// ══════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════
let currentStoreId = null;

(function(){
  const sel = document.getElementById('gate-store');
  STORES.forEach(s => {
    const o = document.createElement('option');
    o.value = s.id; o.textContent = s.name;
    sel.appendChild(o);
  });
})();

// ══════════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════════
function todayKey(){
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}
function fmt(n){ return Number(n||0).toLocaleString('az-AZ',{minimumFractionDigits:0,maximumFractionDigits:0}); }
function formatDate(){ return new Date().toLocaleDateString('az-AZ',{weekday:'long',year:'numeric',month:'long',day:'numeric'}); }
function formatDateShort(){ return new Date().toLocaleDateString('az-AZ',{day:'numeric',month:'long'}); }

// Local cache key per store+year
function cacheKey(storeId, year){ return `panda_${storeId}_${year}_${todayKey()}`; }
function getCached(storeId, year){ try{ return JSON.parse(localStorage.getItem(cacheKey(storeId,year))||'null'); }catch{ return null; } }
function setCached(storeId, year, data){ localStorage.setItem(cacheKey(storeId,year), JSON.stringify(data)); }

// ══════════════════════════════════════════════
// NAVIGATION
// ══════════════════════════════════════════════
function goTo(id){
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function logout(){
  currentStoreId = null;
  document.getElementById('gate-pw').value = '';
  document.getElementById('gate-err').classList.remove('show');
  document.getElementById('gate-store').value = '';
  goTo('gate');
}

// ══════════════════════════════════════════════
// LOGIN
// ══════════════════════════════════════════════
function doLogin(){
  const sid = document.getElementById('gate-store').value;
  const pw  = document.getElementById('gate-pw').value;
  if(!sid){ alert('Zəhmət olmasa şöbəni seçin.'); return; }
  const store = STORES.find(s => s.id === sid);
  if(!store || pw !== store.pw){
    document.getElementById('gate-err').classList.add('show');
    document.getElementById('gate-pw').value = '';
    return;
  }
  document.getElementById('gate-err').classList.remove('show');
  currentStoreId = sid;
  openStoreForm(sid);
}

function showAdminGate(){
  const pw = prompt('Admin şifrəsi:');
  if(pw === ADMIN_PW){ openAdmin(); }
  else if(pw !== null){ alert('Şifrə yanlışdır.'); }
}

// ══════════════════════════════════════════════
// STORE FORM
// ══════════════════════════════════════════════
function openStoreForm(storeId){
  const store = STORES.find(s => s.id === storeId);
  const isSaxa = SAXA_IDS.includes(storeId);
  const years = isSaxa ? [YEARS[0]] : YEARS;

  document.getElementById('sf-title').textContent = store.name;
  document.getElementById('sf-date').textContent = formatDate();

  const body = document.getElementById('sf-body');
  const allSaved = years.every(y => getCached(storeId, y) !== null);

  let html = '';
  years.forEach((year, yi) => {
    const saved = getCached(storeId, year);
    const dis = saved ? 'disabled' : '';
    html += `
    <div class="year-block">
      <div class="year-header" style="background:${YEAR_HDR[yi]}">${year}-ci il — ${formatDateShort()}</div>
      <table class="year-table">
        <thead><tr>
          <th style="text-align:left">Göstərici</th>
          <th>Satış Məbləği (₼)</th>
          <th>Mənfəət (₼)</th>
          <th>Faiz (%)</th>
        </tr></thead>
        <tbody><tr>
          <td class="pname">Ümumi satış</td>
          <td><input class="num-inp" type="number" min="0" step="0.01" id="satis-${year}" value="${saved?.satis??''}" placeholder="0.00" ${dis}></td>
          <td><input class="num-inp" type="number" min="0" step="0.01" id="menfeet-${year}" value="${saved?.menfeet??''}" placeholder="0.00" ${dis}></td>
          <td><input class="num-inp" type="number" min="0" step="0.1" id="faiz-${year}" value="${saved?.faiz??''}" placeholder="0.0" ${dis}></td>
        </tr></tbody>
      </table>
    </div>`;
  });

  html += `
  <button class="sf-save-btn" id="sf-save-btn" onclick="submitStore()" ${allSaved?'disabled':''}>
    ${allSaved ? '✓ Saxlanıldı' : '✓ Yadda Saxla'}
  </button>
  <div class="loading-box" id="sf-loading">⏳ Məlumatlar göndərilir...</div>
  <div class="success-box ${allSaved?'show':''}" id="sf-success">✅ Məlumatlar uğurla saxlandı!</div>
  <div class="error-box" id="sf-error">❌ Xəta baş verdi. Yenidən cəhd edin.</div>`;

  body.innerHTML = html;
  goTo('store-form');
}

async function submitStore(){
  const storeId = currentStoreId;
  const store = STORES.find(s => s.id === storeId);
  const isSaxa = SAXA_IDS.includes(storeId);
  const years = isSaxa ? [YEARS[0]] : YEARS;

  const results = {};
  let anyData = false;
  for(const year of years){
    const s = parseFloat(document.getElementById(`satis-${year}`)?.value)||0;
    const m = parseFloat(document.getElementById(`menfeet-${year}`)?.value)||0;
    const f = parseFloat(document.getElementById(`faiz-${year}`)?.value)||0;
    if(s>0||m>0||f>0) anyData = true;
    results[year] = {satis:s, menfeet:m, faiz:f};
  }
  if(!anyData){ alert('Ən azı bir rəqəm daxil edin.'); return; }

  document.getElementById('sf-save-btn').disabled = true;
  document.getElementById('sf-loading').classList.add('show');
  document.getElementById('sf-error').classList.remove('show');

  try {
    const sends = [];
    for(const year of years){
      const d = results[year];
      sends.push(fetch(API_URL, {
        method:'POST',
        body: JSON.stringify({
          tarix: todayKey(),
          sobe: store.name,
          il: year,
          satis: d.satis,
          menfeet: d.menfeet,
          faiz: d.faiz
        })
      }));
    }
    await Promise.all(sends);

    // Cache locally
    for(const year of years){ setCached(storeId, year, results[year]); }

    document.getElementById('sf-loading').classList.remove('show');
    document.getElementById('sf-success').classList.add('show');
    document.getElementById('sf-save-btn').textContent = '✓ Saxlanıldı';
    document.querySelectorAll('.num-inp').forEach(i => i.disabled = true);
  } catch(err) {
    document.getElementById('sf-loading').classList.remove('show');
    document.getElementById('sf-error').classList.add('show');
    document.getElementById('sf-save-btn').disabled = false;
  }
}

// ══════════════════════════════════════════════
// ADMIN
// ══════════════════════════════════════════════
function openAdmin(){
  document.getElementById('adm-date').textContent = formatDate();
  goTo('admin');
  loadAdminData();
}

async function loadAdminData(){
  document.getElementById('adm-loading').style.display = 'block';
  document.getElementById('report-tbl').style.display = 'none';

  try {
    const res = await fetch(API_URL + '?t=' + Date.now());
    const json = await res.json();
    buildReport(json.data || []);
  } catch(e) {
    document.getElementById('adm-loading').textContent = '❌ Məlumatlar yüklənmədi. Yenilə düyməsinə bas.';
  }
}

function buildReport(rows){
  const today = todayKey();

  // Filter today's rows
  const todayRows = rows.filter(r => {
    const t = r['Tarix'] || r['tarix'] || '';
    return String(t).trim() === today;
  });

  // Build data structure: { storeName: { year: {satis, menfeet, faiz} } }
  const data = {};
  STORES.forEach(s => { data[s.name] = {}; });

  todayRows.forEach(r => {
    const sobe = r['Şöbə'] || r['sobe'] || '';
    const il   = parseInt(r['İl'] || r['il'] || 0);
    const satis   = parseFloat(r['Satış'] || r['satis'] || 0);
    const menfeet = parseFloat(r['Mənfəət'] || r['menfeet'] || 0);
    const faiz    = parseFloat(r['Faiz'] || r['faiz'] || 0);
    if(data[sobe] !== undefined && il){
      data[sobe][il] = {satis, menfeet, faiz};
    }
  });

  const d = new Date();
  const tbl = document.getElementById('report-tbl');

  // THEAD
  let thead = `<thead>
  <tr class="rh-group">
    <th class="th-lbl" style="background:#2d2d2d">Şöbələr</th>`;
  YEARS.forEach((y,i) => {
    thead += `<th colspan="3" class="${YEAR_BG[i]}">${d.getDate()} mart ${y}</th>`;
  });
  thead += `</tr><tr class="rh-sub"><th class="th-lbl" style="background:#3a3a3a"></th>`;
  YEARS.forEach((y,i) => {
    thead += `<th class="${YEAR_SUB[i]}">Satış məbləği</th><th class="${YEAR_SUB[i]}">Mənfəət</th><th class="${YEAR_SUB[i]}">Faiz</th>`;
  });
  thead += `</tr></thead>`;

  // TBODY
  let tbody = '<tbody>';
  const totals = YEARS.map(() => ({s:0, m:0, count:0}));

  STORES.forEach(store => {
    const isSaxa = SAXA_IDS.includes(store.id);
    tbody += `<tr><td class="td-name">${store.name}</td>`;
    YEARS.forEach((year, yi) => {
      if(isSaxa && year !== YEARS[0]){
        tbody += `<td class="td-dash">—</td><td class="td-dash">—</td><td class="td-dash">—</td>`;
      } else {
        const e = data[store.name]?.[year];
        if(e){
          tbody += `<td class="td-num">${fmt(e.satis)}</td><td class="td-num">${fmt(e.menfeet)}</td><td class="td-pct">${e.faiz ? e.faiz+'%' : '—'}</td>`;
          if(!isSaxa){ totals[yi].s += e.satis; totals[yi].m += e.menfeet; totals[yi].count++; }
        } else {
          tbody += `<td class="td-dash">—</td><td class="td-dash">—</td><td class="td-dash">—</td>`;
        }
      }
    });
    tbody += '</tr>';
  });
  tbody += '</tbody>';

  // TFOOT
  let tfoot = '<tfoot><tr><td class="td-name">Ümumi Panda</td>';
  totals.forEach(t => {
    const pct = t.s > 0 ? Math.round(t.m/t.s*100)+'%' : '—';
    tfoot += `<td class="td-num">${t.count ? fmt(t.s) : '—'}</td><td class="td-num">${t.count ? fmt(t.m) : '—'}</td><td class="td-pct">${t.count ? pct : '—'}</td>`;
  });
  tfoot += '</tr></tfoot>';

  tbl.innerHTML = thead + tbody + tfoot;
  document.getElementById('adm-loading').style.display = 'none';
  tbl.style.display = 'table';
}
</script>

</body>
</html>
